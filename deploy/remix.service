[Unit]
Description=Remix App (React Router)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/remix
ExecStart=/usr/bin/npx react-router-serve ./build/server/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
